  },
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nwthomas/website.git"
  },
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.19",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "postbuild": "node scripts/postbuild.mjs",
    "preview": "vite preview",
    "lint": "eslint src vite.config.ts eslint.config.mjs scripts",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,mdx}\" vite.config.ts eslint.config.mjs tailwind.config.js",
    "preinstall": "npx only-allow bun",
    "postinstall": "bun ./fonts/init.ts",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@mdx-js/react": "3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@reduxjs/toolkit": "2.11.2",
    "@sentry/node": "^10.52.0",
    "@sentry/react": "^10.52.0",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-start": "^1.167.65",
    "@types/mdx": "2.0.13",
    "@vercel/analytics": "2.0.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "2.0.0",
    "clsx": "2.1.1",
    "focus-trap-react": "12.0.0",
    "geist": "1.7.0",
    "postcss": "8.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-redux": "9.2.0",
    "redis": "5.11.0",
    "redux": "5.0.1",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@sparticuz/chromium": "143.0.4",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@vitejs/plugin-react": "^6",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.4",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "^17.6.0",
    "nitro": "3.0.260311-beta",
    "playwright-core": "1.58.2",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8"
  },
  "engines": {
    "node": "24"
  }
